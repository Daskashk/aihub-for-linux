{
  "name": "aihub-desktop",
  "version": "0.6.2-beta",
  "description": "All-in-one AI assistants desktop app",
  "main": "main.js",
  "author": "Daskashk",
  "license": "GPL-3.0",
  "scripts": {
    "start": "electron .",
    "build:linux": "electron-builder --linux",
    "build:ci": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.aihub.desktop",
    "productName": "AI Hub Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.json",
      "ui/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Utility",
      "icon": "ui/assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^24.9.1"
  }
}
