{
  "name": "aihub-desktop",
  "version": "0.6.3-beta",
  "description": "All-in-one AI assistants desktop app",
  "main": "main.js",
  "author": "Daskashk <130722296+Daskashk@users.noreply.github.com>",
  "license": "GPL-3.0",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder -mwl",
    "build:ci": "electron-builder --publish never"
  },

  "build": {
    "appId": "com.aihub.desktop",
    "productName": "AI Hub Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!**/.git/**",
      "!**/*.log",
      "!**/node_modules/.cache/**",
      "!**/*.map"
    ],

    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "category": "Utility",
      "icon": "ui/assets/icon.png"
    },

    "win": {
      "target": "nsis",
      "icon": "ui/assets/icon.ico"
    },

    "mac": {
      "target": "dmg",
      "icon": "ui/assets/icon.icns",
      "category": "public.app-category.productivity"
    },

    "publish": null
  },

  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^24.9.1"
  }
}
